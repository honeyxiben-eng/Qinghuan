# ============================================
# 智慧盐湖平台 - 生产环境变量
# 部署到腾讯云前修改这些值
# ============================================

# JWT 密钥（务必改成随机字符串！）
JWT_SECRET=saltlake-jwt-change-me-to-random-string

# 通义千问 API Key（智能问答功能）
DASHSCOPE_API_KEY=sk-your-key-here

# 数据库默认使用本地 SQLite (/app/prisma/saltlake.db)
# 如果要用 Turso，取消下面两行注释
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token
